#!/usr/bin/env python3
"""
Utility to read/write files on an ICARUS OS disk image.

Usage:
    idu format
    idu list
    idu write <name> <file>
    idu read <name> [outfile]
    idu delete <name>

Options:
    -f <path>   Disk image file (default: disk.img)

Create a new disk image:
    dd if=/dev/zero of=disk.img bs=1M count=1
"""

import struct
import sys
import os

SECTOR_SIZE = 512
FS_MAGIC = 0x49434152  # "ICAR"
FS_MAX_FILES = 32
FS_NAME_LEN = 32
FS_DATA_START = 33

def read_sector(f, lba):
    f.seek(lba * SECTOR_SIZE)
    return f.read(SECTOR_SIZE)

def write_sector(f, lba, data):
    assert len(data) == SECTOR_SIZE
    f.seek(lba * SECTOR_SIZE)
    f.write(data)

def read_header(f):
    raw = read_sector(f, 0)
    magic, file_count = struct.unpack_from('<II', raw, 0)
    return magic, file_count

def write_header(f, file_count):
    raw = bytearray(SECTOR_SIZE)
    struct.pack_into('<II', raw, 0, FS_MAGIC, file_count)
    write_sector(f, 0, bytes(raw))

def read_entry(f, idx):
    raw = read_sector(f, 1 + idx)
    name = raw[:FS_NAME_LEN].split(b'\x00')[0].decode('ascii', errors='replace')
    start_sector, size_bytes = struct.unpack_from('<II', raw, FS_NAME_LEN)
    return name, start_sector, size_bytes

def write_entry(f, idx, name, start_sector, size_bytes):
    raw = bytearray(SECTOR_SIZE)
    name_bytes = name.encode('ascii')[:FS_NAME_LEN - 1]
    raw[:len(name_bytes)] = name_bytes
    struct.pack_into('<II', raw, FS_NAME_LEN, start_sector, size_bytes)
    write_sector(f, 1 + idx, bytes(raw))

def cmd_format(f):
    disk_size = f.seek(0, 2)
    f.seek(0)
    write_header(f, 0)
    empty = bytes(SECTOR_SIZE)
    for i in range(FS_MAX_FILES):
        write_sector(f, 1 + i, empty)
    print(f"Formatted ({disk_size} bytes)")

def cmd_list(f):
    magic, file_count = read_header(f)
    if magic != FS_MAGIC:
        print("Disk not formatted")
        return
    if file_count == 0:
        print("(no files)")
    else:
        for i in range(file_count):
            name, start, size = read_entry(f, i)
            print(f"  {name:<12s} {size} bytes")

    # Free space
    disk_size = f.seek(0, 2)
    total_sectors = disk_size // SECTOR_SIZE
    next_free = FS_DATA_START
    for i in range(file_count):
        name, start, size = read_entry(f, i)
        end = start + (size + SECTOR_SIZE - 1) // SECTOR_SIZE
        if end > next_free:
            next_free = end
    free_sectors = total_sectors - next_free
    print(f"\n  {file_count} files, {free_sectors * SECTOR_SIZE} bytes free")

def find_free_sector(f, file_count):
    next_free = FS_DATA_START
    for i in range(file_count):
        name, start, size = read_entry(f, i)
        end = start + (size + SECTOR_SIZE - 1) // SECTOR_SIZE
        if end > next_free:
            next_free = end
    return next_free

def cmd_write(f, name, filepath):
    magic, file_count = read_header(f)
    if magic != FS_MAGIC:
        print("Disk not formatted")
        return

    with open(filepath, 'rb') as src:
        data = src.read()

    # Delete existing file with same name
    cmd_delete(f, name, quiet=True)
    # Re-read header after possible delete
    magic, file_count = read_header(f)

    if file_count >= FS_MAX_FILES:
        print("Directory full")
        return

    start = find_free_sector(f, file_count)
    sectors_needed = (len(data) + SECTOR_SIZE - 1) // SECTOR_SIZE

    # Write data sectors
    for s in range(sectors_needed):
        chunk = data[s * SECTOR_SIZE:(s + 1) * SECTOR_SIZE]
        sector = chunk.ljust(SECTOR_SIZE, b'\x00')
        write_sector(f, start + s, sector)

    # Write directory entry
    write_entry(f, file_count, name, start, len(data))

    # Update header
    write_header(f, file_count + 1)

    print(f"Wrote '{name}' ({len(data)} bytes)")

def cmd_read(f, name, outfile=None):
    magic, file_count = read_header(f)
    if magic != FS_MAGIC:
        print("Disk not formatted")
        return

    for i in range(file_count):
        entry_name, start, size = read_entry(f, i)
        if entry_name == name:
            data = bytearray()
            sectors = (size + SECTOR_SIZE - 1) // SECTOR_SIZE
            for s in range(sectors):
                raw = read_sector(f, start + s)
                data.extend(raw)
            data = data[:size]

            if outfile:
                with open(outfile, 'wb') as dst:
                    dst.write(data)
                print(f"Read '{name}' ({size} bytes) -> {outfile}")
            else:
                sys.stdout.buffer.write(data)
            return

    print(f"File not found: {name}")

def cmd_delete(f, name, quiet=False):
    magic, file_count = read_header(f)
    if magic != FS_MAGIC:
        if not quiet:
            print("Disk not formatted")
        return

    for i in range(file_count):
        entry_name, start, size = read_entry(f, i)
        if entry_name == name:
            # Shift remaining entries down
            for j in range(i, file_count - 1):
                n, s, sz = read_entry(f, j + 1)
                write_entry(f, j, n, s, sz)
            write_header(f, file_count - 1)
            if not quiet:
                print(f"Deleted '{name}'")
            return

    if not quiet:
        print(f"File not found: {name}")

def main():
    args = sys.argv[1:]
    disk_path = 'disk.img'

    # Parse -f flag
    if '-f' in args:
        idx = args.index('-f')
        if idx + 1 < len(args):
            disk_path = args[idx + 1]
            args = args[:idx] + args[idx + 2:]
        else:
            print("Error: -f requires a path")
            sys.exit(1)

    if len(args) < 1:
        print(__doc__)
        sys.exit(1)

    command = args[0]

    mode = 'r+b' if os.path.exists(disk_path) else 'w+b'
    with open(disk_path, mode) as f:
        if command == 'format':
            cmd_format(f)
        elif command == 'list':
            cmd_list(f)
        elif command == 'write':
            if len(args) < 3:
                print("Usage: idu write <name> <file>")
                sys.exit(1)
            cmd_write(f, args[1], args[2])
        elif command == 'read':
            if len(args) < 2:
                print("Usage: idu read <name> [outfile]")
                sys.exit(1)
            outfile = args[2] if len(args) > 2 else None
            cmd_read(f, args[1], outfile)
        elif command == 'delete':
            if len(args) < 2:
                print("Usage: idu delete <name>")
                sys.exit(1)
            cmd_delete(f, args[1])
        else:
            print(f"Unknown command: {command}")
            sys.exit(1)

if __name__ == '__main__':
    main()
