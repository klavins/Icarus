140 REM
200 REM ---- MODE 1: 320x200 ----
210 GRAPHICS 1
220 LET W = SCRW - 1
230 LET H = SCRH - 1
240 REM Draw border
250 COLOR 4
260 PLOT 0, 0
270 DRAWTO W, 0
280 DRAWTO W, H
290 DRAWTO 0, H
300 DRAWTO 0, 0
305 REM Draw circle
306 COLOR 10
307 LET CR = SCRH / 2 - 10
308 GOSUB 5000
310 REM Draw centered text
320 COLOR 15
330 POS SCRW / 2 - 44, SCRH / 2 - 50
340 TEXT "GRAPHICS 1"
350 COLOR 14
360 POS SCRW / 2 - 36, SCRH / 2 - 30
370 TEXT "320 x 200"
380 COLOR 2
390 POS SCRW / 2 - 56, SCRH / 2 - 10
400 TEXT "CHUNKY PIXELS"
410 COLOR 1
420 POS SCRW / 2 - 52, SCRH / 2 + 10
430 TEXT "PRESS ANY KEY"
440 SHOW
445 PAUSE
