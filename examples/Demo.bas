1400 REM ---- RETURN TO TEXT ----
1410 GRAPHICS 0
1420 GOTO 9999
5000 REM ---- Draw circle at center ----
5010 LET CX = SCRW / 2
5020 LET CY = SCRH / 2
5030 LET ST = 36
5040 LET DA = 2 * PI / ST
5050 PLOT CX + CR, CY
5060 FOR I = 1 TO ST
5070 LET PX = CX + INT(CR * COS(I * DA))
5080 LET PY = CY + INT(CR * SIN(I * DA))
5090 DRAWTO PX, PY
5100 NEXT I
5110 RETURN
9999 REM END
