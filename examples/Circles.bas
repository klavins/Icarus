10 REM ========================
20 REM   CIRCLES DEMO
30 REM   Draws concentric and
40 REM   random circles using
50 REM   SIN, COS, and PI
60 REM ========================
70 REM
100 GRAPHICS 4
110 LET CX = SCRW / 2
120 LET CY = SCRH / 2
130 REM
200 REM ---- CONCENTRIC CIRCLES ----
210 FOR R = 20 TO 300 STEP 20
220 LET C = R / 20
230 IF C > 15 THEN LET C = C - 15
240 COLOR C
250 GOSUB 1000
260 NEXT R
270 REM
300 REM ---- RANDOM CIRCLES ----
310 FOR N = 1 TO 40
320 LET CX = RND(SCRW)
330 LET CY = RND(SCRH)
340 LET R = RND(80) + 10
350 COLOR RND(15) + 1
360 GOSUB 1000
370 NEXT N
380 REM
400 REM ---- TITLE ----
410 COLOR 15
420 POS SCRW / 2 - 48, 10
430 TEXT "CIRCLES DEMO"
440 COLOR 14
450 POS SCRW / 2 - 84, SCRH - 26
460 TEXT "PRESS ANY KEY TO EXIT"
470 REM
500 PAUSE
510 GRAPHICS 0
520 PRINT "DONE"
530 GOTO 9999
540 REM
1000 REM ---- DRAW CIRCLE ----
1010 REM Uses CX, CY, R
1020 LET STEPS = R
1030 IF STEPS < 30 THEN LET STEPS = 30
1040 IF STEPS > 120 THEN LET STEPS = 120
1050 LET DA = 2 * PI / STEPS
1060 PLOT CX + R, CY
1070 FOR A = 1 TO STEPS
1080 LET PX = CX + INT(R * COS(A * DA))
1090 LET PY = CY + INT(R * SIN(A * DA))
1100 DRAWTO PX, PY
1110 NEXT A
1120 RETURN
1130 REM
9999 REM END
