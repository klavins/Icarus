10 GRAPHICS 2

20 LET PX = SCRW / 2
30 LET PY = SCRH - 20
40 LET BX = SCRW / 2
50 LET BY = SCRH / 2
60 LET DBX = 0.5
70 LET DBY = 0.5

100 COLOR 0
110 GOSUB 1000

200 IF PEEK(0x7004B) = 0 THEN LET PX = PX + 1
220 IF PEEK(0x7004D) = 0 THEN LET PX = PX - 1
230 IF PX <= 10 THEN LET PX = 10
240 IF PX >= SCRW - 10 THEN LET PX = SCRW - 10

250 IF BX + DBX < 0    THEN LET DBX = -DBX
251 IF BX + DBX > SCRW THEN LET DBX = -DBX
252 IF BY + DBY < 0    THEN LET DBY = -DBY
253 IF BY + DBY > SCRH THEN LET DBY = -DBY

260 IF BX + DBX >= PX - 10 AND BX + DBX <= PX + 10 AND BY + DBY >= SCRH - 20 THEN LET DBY = -DBY

290 LET BX = BX + DBX
291 LET BY = BY + DBY

300 COLOR 11
310 GOSUB 1000

400 SHOW
410 DELAY 1

520 GOTO 100

1000 PLOT PX-10, PY
1010 DRAWTO PX+10,PY
1020 POS BX-1, BY-1
1030 FILLTO BX+1, BY+1

1050 RETURN

9999 REM == DONE ==