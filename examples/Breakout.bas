10 GRAPHICS 2

20 LET PX = SCRW / 2
30 LET PY = SCRH - 20
40 LET BX = SCRW / 2
50 LET BY = SCRH / 2
60 LET DBX = 0.5
70 LET DBY = 0.5
80 LET VOL = 0
90 LET PITCH = 100

100 COLOR 0
110 SOUND 0,PITCH,0,VOL
120 IF VOL > 0 THEN LET VOL = VOL - 1

130 GOSUB 500

140 IF PEEK(0x7004D) = 1 THEN LET PX = PX + 1
150 IF PEEK(0x7004B) = 1 THEN LET PX = PX - 1
160 IF PX <= 10 THEN LET PX = 10
170 IF PX >= SCRW - 10 THEN LET PX = SCRW - 10

180 IF BX + DBX < 0 OR BX + DBX > SCRW THEN GOSUB 220
190 GOTO 260

200 REM -- Wall X bounce --
210 REM
220 LET DBX = -DBX
230 IF VOL = 0 THEN LET VOL = 10
240 IF VOL = 10 THEN LET PITCH = 120
250 RETURN

260 IF BY + DBY < 0 THEN GOSUB 310
270 IF BY + DBY > SCRH THEN GOSUB 310
280 GOTO 350

290 REM -- Wall Y bounce --
300 REM
310 LET DBY = -DBY
320 IF VOL = 0 THEN LET VOL = 10
330 IF VOL = 10 THEN LET PITCH = 120
340 RETURN

350 IF BX + DBX >= PX - 10 AND BX + DBX <= PX + 10 AND BY + DBY >= SCRH - 20 THEN GOSUB 390
360 GOTO 430

370 REM -- Paddle bounce --
380 REM
390 LET DBY = -DBY
400 LET VOL = 10
410 LET PITCH = 40
420 RETURN

430 LET BX = BX + DBX
440 LET BY = BY + DBY

450 COLOR 11
460 GOSUB 500

470 SHOW
480 DELAY 1

490 GOTO 100

500 PLOT PX-10, PY
510 DRAWTO PX+10,PY
520 POS BX-1, BY-1
530 FILLTO BX+1, BY+1
540 RETURN
