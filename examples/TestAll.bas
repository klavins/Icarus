10 REM ================================
20 REM   ICARUS BASIC TEST SUITE
30 REM   Tests all language features
40 REM   Each test prints PASS or FAIL
50 REM ================================
60 REM
70 LET PASS = 0
80 LET FAIL = 0
90 LET TEST = 0
100 REM
200 REM ---- ARITHMETIC ----
210 LET TEST = TEST + 1
220 IF 2 + 3 = 5 THEN GOSUB 9000
230 IF 2 + 3 <> 5 THEN GOSUB 9100
240 LET TEST = TEST + 1
250 IF 10 - 7 = 3 THEN GOSUB 9000
260 IF 10 - 7 <> 3 THEN GOSUB 9100
270 LET TEST = TEST + 1
280 IF 6 * 7 = 42 THEN GOSUB 9000
290 IF 6 * 7 <> 42 THEN GOSUB 9100
300 LET TEST = TEST + 1
310 IF 15 / 3 = 5 THEN GOSUB 9000
320 IF 15 / 3 <> 5 THEN GOSUB 9100
330 LET TEST = TEST + 1
340 IF 2 + 3 * 4 = 14 THEN GOSUB 9000
350 IF 2 + 3 * 4 <> 14 THEN GOSUB 9100
360 LET TEST = TEST + 1
370 IF (2 + 3) * 4 = 20 THEN GOSUB 9000
380 IF (2 + 3) * 4 <> 20 THEN GOSUB 9100
390 REM
400 REM ---- FLOAT ARITHMETIC ----
410 LET TEST = TEST + 1
420 LET X = 1 / 3
430 IF X > 0.333 THEN IF X < 0.334 THEN GOSUB 9000
440 IF X <= 0.333 THEN GOSUB 9100
450 IF X >= 0.334 THEN GOSUB 9100
460 LET TEST = TEST + 1
470 IF 3.14 * 2 = 6.28 THEN GOSUB 9000
480 IF 3.14 * 2 <> 6.28 THEN GOSUB 9100
490 REM
500 REM ---- COMPARISONS ----
510 LET TEST = TEST + 1
520 IF 5 > 3 THEN GOSUB 9000
530 IF 5 <= 3 THEN GOSUB 9100
540 LET TEST = TEST + 1
550 IF 3 < 5 THEN GOSUB 9000
560 IF 3 >= 5 THEN GOSUB 9100
570 LET TEST = TEST + 1
580 IF 5 >= 5 THEN GOSUB 9000
590 IF 5 < 5 THEN GOSUB 9100
600 LET TEST = TEST + 1
610 IF 5 <= 5 THEN GOSUB 9000
620 IF 5 > 5 THEN GOSUB 9100
630 LET TEST = TEST + 1
640 IF 3 <> 5 THEN GOSUB 9000
650 IF 3 = 5 THEN GOSUB 9100
660 REM
700 REM ---- VARIABLES ----
710 LET TEST = TEST + 1
720 LET SCORE = 100
730 IF SCORE = 100 THEN GOSUB 9000
740 IF SCORE <> 100 THEN GOSUB 9100
750 LET TEST = TEST + 1
760 LET X = 10
770 LET Y = 20
780 IF X + Y = 30 THEN GOSUB 9000
790 IF X + Y <> 30 THEN GOSUB 9100
800 REM
900 REM ---- STRINGS ----
910 LET TEST = TEST + 1
920 DIM A$(20)
930 LET A$ = "HELLO"
940 IF LEN(A$) = 5 THEN GOSUB 9000
950 IF LEN(A$) <> 5 THEN GOSUB 9100
960 REM
1000 REM ---- ARRAYS ----
1010 LET TEST = TEST + 1
1020 DIM ARR(5)
1030 LET ARR(0) = 10
1040 LET ARR(4) = 50
1050 IF ARR(0) + ARR(4) = 60 THEN GOSUB 9000
1060 IF ARR(0) + ARR(4) <> 60 THEN GOSUB 9100
1070 LET TEST = TEST + 1
1080 DIM M(3, 3)
1090 LET M(1, 2) = 99
1100 IF M(1, 2) = 99 THEN GOSUB 9000
1110 IF M(1, 2) <> 99 THEN GOSUB 9100
1120 REM
1200 REM ---- FOR/NEXT ----
1210 LET TEST = TEST + 1
1220 LET S = 0
1230 FOR I = 1 TO 5
1240 LET S = S + I
1250 NEXT I
1260 IF S = 15 THEN GOSUB 9000
1270 IF S <> 15 THEN GOSUB 9100
1280 LET TEST = TEST + 1
1290 LET S = 0
1300 FOR I = 10 TO 0 STEP -2
1310 LET S = S + 1
1320 NEXT I
1330 IF S = 6 THEN GOSUB 9000
1340 IF S <> 6 THEN GOSUB 9100
1350 REM
1400 REM ---- NESTED FOR ----
1410 LET TEST = TEST + 1
1420 LET S = 0
1430 FOR I = 1 TO 3
1440 FOR J = 1 TO 3
1450 LET S = S + 1
1460 NEXT J
1470 NEXT I
1480 IF S = 9 THEN GOSUB 9000
1490 IF S <> 9 THEN GOSUB 9100
1500 REM
1600 REM ---- GOSUB/RETURN ----
1610 LET TEST = TEST + 1
1620 LET X = 0
1630 GOSUB 8000
1640 IF X = 42 THEN GOSUB 9000
1650 IF X <> 42 THEN GOSUB 9100
1660 REM
1700 REM ---- ON GOTO ----
1710 LET TEST = TEST + 1
1720 LET X = 2
1730 ON X GOTO 1750, 1760, 1770
1740 GOTO 1780
1750 LET X = 10
1755 GOTO 1780
1760 LET X = 20
1765 GOTO 1780
1770 LET X = 30
1780 IF X = 20 THEN GOSUB 9000
1790 IF X <> 20 THEN GOSUB 9100
1800 REM
1900 REM ---- DATA/READ ----
1910 LET TEST = TEST + 1
1920 DATA 100, 200, 300
1930 READ X
1940 READ Y
1950 READ Z
1960 IF X + Y + Z = 600 THEN GOSUB 9000
1970 IF X + Y + Z <> 600 THEN GOSUB 9100
1980 REM
2000 REM ---- MATH FUNCTIONS ----
2010 LET TEST = TEST + 1
2020 IF ABS(-5) = 5 THEN GOSUB 9000
2030 IF ABS(-5) <> 5 THEN GOSUB 9100
2040 LET TEST = TEST + 1
2050 IF INT(3.7) = 3 THEN GOSUB 9000
2060 IF INT(3.7) <> 3 THEN GOSUB 9100
2070 LET TEST = TEST + 1
2080 IF SQR(144) = 12 THEN GOSUB 9000
2090 IF SQR(144) <> 12 THEN GOSUB 9100
2100 LET TEST = TEST + 1
2110 LET X = SIN(0)
2120 IF X = 0 THEN GOSUB 9000
2130 IF X <> 0 THEN GOSUB 9100
2140 LET TEST = TEST + 1
2150 LET X = COS(0)
2160 IF X = 1 THEN GOSUB 9000
2170 IF X <> 1 THEN GOSUB 9100
2180 LET TEST = TEST + 1
2190 LET X = SIN(PI / 2)
2200 IF X > 0.999 THEN GOSUB 9000
2210 IF X <= 0.999 THEN GOSUB 9100
2220 REM
2300 REM ---- RND ----
2310 LET TEST = TEST + 1
2320 LET X = RND(100)
2330 IF X >= 0 THEN IF X < 100 THEN GOSUB 9000
2340 IF X < 0 THEN GOSUB 9100
2350 IF X >= 100 THEN GOSUB 9100
2360 LET TEST = TEST + 1
2370 LET X = RND
2380 IF X >= 0 THEN IF X < 1 THEN GOSUB 9000
2390 IF X < 0 THEN GOSUB 9100
2400 IF X >= 1 THEN GOSUB 9100
2410 REM
2500 REM ---- HEX NUMBERS ----
2510 LET TEST = TEST + 1
2520 IF 0xFF = 255 THEN GOSUB 9000
2530 IF 0xFF <> 255 THEN GOSUB 9100
2540 LET TEST = TEST + 1
2550 IF 0x10 = 16 THEN GOSUB 9000
2560 IF 0x10 <> 16 THEN GOSUB 9100
2570 REM
2600 REM ---- PI ----
2610 LET TEST = TEST + 1
2620 IF PI > 3.14 THEN IF PI < 3.15 THEN GOSUB 9000
2630 IF PI <= 3.14 THEN GOSUB 9100
2640 IF PI >= 3.15 THEN GOSUB 9100
2650 REM
2700 REM ---- PEEK/POKE ----
2710 LET TEST = TEST + 1
2720 POKE 0x70090, 42
2730 IF PEEK(0x70090) = 42 THEN GOSUB 9000
2740 IF PEEK(0x70090) <> 42 THEN GOSUB 9100
2750 POKE 0x70090, 0
2760 REM
2800 REM ---- SCRW/SCRH ----
2810 LET TEST = TEST + 1
2820 IF SCRW > 0 THEN GOSUB 9000
2830 IF SCRW <= 0 THEN GOSUB 9100
2840 LET TEST = TEST + 1
2850 IF SCRH > 0 THEN GOSUB 9000
2860 IF SCRH <= 0 THEN GOSUB 9100
2870 REM
3000 REM ---- FLOAT FOR LOOP ----
3010 LET TEST = TEST + 1
3020 LET S = 0
3030 FOR X = 0 TO 1 STEP 0.25
3040 LET S = S + 1
3050 NEXT X
3060 IF S = 5 THEN GOSUB 9000
3070 IF S <> 5 THEN GOSUB 9100
3080 REM
3090 REM ---- MOD OPERATOR ----
3091 LET TEST = TEST + 1
3092 IF 10 MOD 3 = 1 THEN GOSUB 9000
3093 IF 10 MOD 3 <> 1 THEN GOSUB 9100
3094 LET TEST = TEST + 1
3095 IF 7 MOD 2 = 1 THEN GOSUB 9000
3096 IF 7 MOD 2 <> 1 THEN GOSUB 9100
3097 LET TEST = TEST + 1
3098 IF 6 MOD 2 = 0 THEN GOSUB 9000
3099 IF 6 MOD 2 <> 0 THEN GOSUB 9100
3100 REM ---- GRAPHICS MODE SWITCHING ----
3110 LET TEST = TEST + 1
3120 LET W0 = SCRW
3130 GRAPHICS 2
3140 IF SCRW = 320 THEN IF SCRH = 200 THEN GOSUB 9000
3150 IF SCRW <> 320 THEN GOSUB 9100
3160 IF SCRH <> 200 THEN GOSUB 9100
3170 GRAPHICS 0
3180 LET TEST = TEST + 1
3190 IF SCRW = W0 THEN GOSUB 9000
3200 IF SCRW <> W0 THEN GOSUB 9100
3210 LET TEST = TEST + 1
3220 GRAPHICS 3
3230 IF SCRW = 640 THEN IF SCRH = 400 THEN GOSUB 9000
3240 IF SCRW <> 640 THEN GOSUB 9100
3250 IF SCRH <> 400 THEN GOSUB 9100
3260 GRAPHICS 0
3270 LET TEST = TEST + 1
3280 GRAPHICS 5
3290 IF SCRW = W0 THEN IF SCRH > 0 THEN GOSUB 9000
3300 IF SCRW <> W0 THEN GOSUB 9100
3310 GRAPHICS 0
3320 REM
3400 REM ---- GRAPHICS PIXEL READBACK ----
3410 REM (skipped: framebuffer address depends on hardware)
3420 REM
5000 REM ================================
5010 REM ---- RESULTS ----
5020 REM ================================
5030 PRINT ""
5040 PRINT "================================"
5050 PRINT "  RESULTS: ", PASS, " PASSED, ", FAIL, " FAILED"
5060 PRINT "  TOTAL:   ", PASS + FAIL, " TESTS"
5070 PRINT "================================"
5080 IF FAIL = 0 THEN PRINT "  ALL TESTS PASSED!"
5090 IF FAIL > 0 THEN PRINT "  *** FAILURES DETECTED ***"
5100 GOTO 9999
5110 REM
8000 REM ---- GOSUB TEST SUB ----
8010 LET X = 42
8020 RETURN
8030 REM
9000 REM ---- PASS ----
9010 LET PASS = PASS + 1
9020 PRINT "  PASS: TEST ", TEST
9030 RETURN
9040 REM
9100 REM ---- FAIL ----
9110 LET FAIL = FAIL + 1
9120 PRINT "  FAIL: TEST ", TEST
9130 RETURN
9140 REM
9999 REM END
