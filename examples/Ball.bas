1 REM ====================
2 REM Bouncing Ball
3 REM ====================

10 LET X = 100
20 LET Y = 700
30 LET DX = 2.5
40 LET DY = 0
50 LET R = 40
60 LET G = 0.5
70 LET KR = 0.8

100 GRAPHICS 4

110 REM Erase old ball area
120 COLOR 0
130 POS INT(X) - R - 1, SCRH - INT(Y) - R - 1
140 FILLTO INT(X) + R + 1, SCRH - INT(Y) + R + 1

150 LET DY = DY - G
160 IF Y + DY <= R THEN LET DY = -KR * DY
170 IF X + DX <= R THEN LET DX = -DX
180 IF X + DX >= SCRW - R THEN LET DX = -DX
190 LET X = X + DX
200 LET Y = Y + DY

210 REM Draw ball
220 COLOR 11
230 GOSUB 1000
240 SHOW
250 DELAY 1

260 LET K = PEEK(0x70081)
270 IF K = 0 THEN GOTO 9999
280 GOTO 110

1000 REM ---- DRAW Ball ----
1010 LET CX = X
1020 LET CY = SCRH - Y
1030 LET ST = 36
1040 LET DA = 2 * PI / ST
1050 PLOT CX + R, CY
1060 FOR A = 1 TO ST
1070 LET PX = CX + INT(R * COS(A * DA))
1080 LET PY = CY + INT(R * SIN(A * DA))
1090 DRAWTO PX, PY
1100 NEXT A
1110 RETURN

9999 GRAPHICS 0
10000 REM END
