1 REM ====================
2 REM Bouncing Ball
3 REM ====================

10 LET X = 100
20 LET Y = 400
30 LET DX = 2.5
40 LET DY = 0
50 LET R = 20
60 LET G = 0.5
70 LET KR = 0.8
80 LET B = 0

100 GRAPHICS 3
110 COLOR 0
120 GOSUB 1000

130 LET DY = DY - G
140 IF Y + DY <= R THEN LET DY = -KR * DY 
141 IF X + DX <= R THEN LET DX = -DX
142 IF X + DX >= 800-R THEN LET DX = -DX

150 LET X = X + DX
160 LET Y = Y + DY

170 COLOR 11
180 GOSUB 1000
190 DELAY 1

200 LET K = PEEK(0x70081)
210 IF K = 0 THEN GOTO 9999

220 GOTO 110

1000 REM ---- DRAW Ball ----
1010 LET CX = X
1015 LET CY = 600-Y
1020 LET STEPS = R
1030 IF STEPS < 30 THEN LET STEPS = 30
1040 IF STEPS > 120 THEN LET STEPS = 120
1050 LET DA = 2 * PI / STEPS
1060 PLOT CX + R, CY
1070 FOR A = 1 TO STEPS
1080 LET PX = CX + INT(R * COS(A * DA))
1090 LET PY = CY + INT(R * SIN(A * DA))
1100 DRAWTO PX, PY
1110 NEXT A
1120 RETURN
1130 REM

9999 GRAPHICS 0
10000 REM END