10 REM ========================
20 REM   KEYBOARD STATE TEST
30 REM   Press keys to see ASCII
40 REM   ESC to exit
50 REM ========================
60 REM
100 PRINT "PRESS KEYS TO SEE STATE"
110 PRINT "ESC TO EXIT"
120 PRINT ""
200 REM ---- MAIN LOOP ----
210 LET K = PEEK(0x70081)
220 IF K = 0 THEN GOTO 200
230 PRINT "KEY: ", K
240 POKE 0x70081, 0
250 IF K = 27 THEN GOTO 300
260 GOTO 200
300 PRINT "DONE"
