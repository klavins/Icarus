10 REM ========================
20 REM   KEYBOARD STATE TEST
30 REM   Shows real-time key state
40 REM   Press ESC to exit
50 REM ========================
60 REM
100 PRINT "PRESS KEYS TO SEE STATE"
110 PRINT "ESC TO EXIT"
120 PRINT ""
130 REM
200 REM ---- MAIN LOOP ----
210 LET K = PEEK(458881)
220 IF K = 0 THEN GOTO 200
230 PRINT "KEY: ", K
240 POKE 458881, 0
250 IF K = 27 THEN GOTO 300
260 GOTO 200
270 REM
300 PRINT "DONE"
