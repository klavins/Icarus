10 REM ========================
20 REM   MOVING DOT
30 REM   Use WASD to move
40 REM   Press SPACE to exit
50 REM ========================
60 REM
70 REM Clear SPACE key state
80 POKE 458809, 0
90 GRAPHICS 1
100 LET X = 160
110 LET Y = 100
120 LET C = 15
130 COLOR C
140 PLOT X, Y
150 REM
200 REM ---- MAIN LOOP ----
210 REM W=458769 A=458782 S=458783 D=458784
220 REM
300 IF PEEK(458769) = 0 THEN GOTO 320
310 LET Y = Y - 1
320 IF PEEK(458783) = 0 THEN GOTO 340
330 LET Y = Y + 1
340 IF PEEK(458782) = 0 THEN GOTO 360
350 LET X = X - 1
360 IF PEEK(458784) = 0 THEN GOTO 380
370 LET X = X + 1
380 REM
400 REM ---- BOUNDS CHECK ----
410 IF X < 0 THEN LET X = 0
420 IF X > 319 THEN LET X = 319
430 IF Y < 0 THEN LET Y = 0
