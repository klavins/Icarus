10 REM ========================
20 REM   MOVING DOT
30 REM   Use WASD to move
40 REM   Press SPACE to exit
50 REM ========================
60 REM
70 REM Clear SPACE key state (scancode 57 at 0x70000+57)
80 POKE 0x70039, 0
90 GRAPHICS 2
100 LET X = 160
110 LET Y = 100
120 LET C = 15
130 COLOR C
140 PLOT X, Y
150 REM
200 REM ---- MAIN LOOP ----
210 REM Key state base=0x70000, W=17, S=31, A=30, D=32
220 REM
300 IF PEEK(0x70011) = 0 THEN GOTO 320
310 LET Y = Y - 1
320 IF PEEK(0x7001F) = 0 THEN GOTO 340
330 LET Y = Y + 1
340 IF PEEK(0x7001E) = 0 THEN GOTO 360
350 LET X = X - 1
360 IF PEEK(0x70020) = 0 THEN GOTO 380
370 LET X = X + 1
380 REM
400 REM ---- BOUNDS CHECK ----
410 IF X < 0 THEN LET X = 0
420 IF X > 319 THEN LET X = 319
430 IF Y < 0 THEN LET Y = 0
440 IF Y > 199 THEN LET Y = 199
450 REM
500 REM ---- DRAW ----
510 COLOR C
520 PLOT X, Y
530 REM
600 REM ---- SHOW AND DELAY ----
610 SHOW
615 DELAY 14
620 IF PEEK(0x70039) = 1 THEN GOTO 700
630 GOTO 300
700 REM ---- EXIT ----
710 GRAPHICS 0
720 PRINT "DONE"
