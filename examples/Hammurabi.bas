10 REM ================================
20 REM   HAMURABI
30 REM   Classic resource management
40 REM   Adapted from David Ahl, 1978
50 REM ================================
60 REM
100 PRINT "HAMURABI"
110 PRINT "CREATIVE COMPUTING"
120 PRINT ""
130 PRINT "TRY YOUR HAND AT GOVERNING"
140 PRINT "ANCIENT SUMERIA FOR A TEN-YEAR"
150 PRINT "TERM OF OFFICE."
160 PRINT ""
170 REM ---- INITIALIZE ----
180 LET D1 = 0
190 LET P1 = 0
200 LET Z = 0
210 LET P = 95
220 LET S = 2800
230 LET H = 3000
240 LET E = H - S
250 LET Y = 3
260 LET A = H / Y
270 LET I = 5
280 LET Q = 1
290 LET D = 0
300 REM
310 REM ---- YEARLY REPORT ----
320 PRINT ""
330 LET Z = Z + 1
340 PRINT "HAMURABI: I BEG TO REPORT,"
350 PRINT "IN YEAR ", Z
360 PRINT D, " PEOPLE STARVED"
370 PRINT I, " CAME TO THE CITY"
380 LET P = P + I
390 IF Q > 0 THEN GOTO 420
400 LET P = P / 2
410 PRINT "A HORRIBLE PLAGUE STRUCK!"
420 PRINT "POPULATION IS NOW ", P
430 PRINT "THE CITY OWNS ", A, " ACRES"
440 PRINT "YOU HARVESTED ", Y, " BUSHELS PER ACRE"
450 PRINT "RATS ATE ", E, " BUSHELS"
460 PRINT "YOU HAVE ", S, " BUSHELS IN STORE"
470 PRINT ""
480 IF Z = 11 THEN GOTO 2000
490 REM
500 REM ---- BUY LAND ----
510 LET C = RND(10)
520 LET Y = C + 17
530 PRINT "LAND IS TRADING AT ", Y, " BUSHELS PER ACRE"
540 INPUT "HOW MANY ACRES TO BUY? ", Q
550 IF Q < 0 THEN GOTO 1900
560 IF Y * Q <= S THEN GOTO 600
570 PRINT "YOU ONLY HAVE ", S, " BUSHELS!"
580 GOTO 540
600 IF Q = 0 THEN GOTO 650
610 LET A = A + Q
620 LET S = S - Y * Q
630 LET C = 0
640 GOTO 700
650 REM ---- SELL LAND ----
660 INPUT "HOW MANY ACRES TO SELL? ", Q
670 IF Q < 0 THEN GOTO 1900
680 IF Q < A THEN GOTO 690
685 PRINT "YOU ONLY OWN ", A, " ACRES!"
686 GOTO 660
690 LET A = A - Q
695 LET S = S + Y * Q
696 LET C = 0
700 REM ---- FEED PEOPLE ----
710 PRINT ""
720 INPUT "BUSHELS TO FEED PEOPLE? ", Q
730 IF Q < 0 THEN GOTO 1900
740 IF Q <= S THEN GOTO 760
750 PRINT "YOU ONLY HAVE ", S, " BUSHELS!"
755 GOTO 720
760 LET S = S - Q
770 LET C = 1
780 PRINT ""
790 REM ---- PLANT CROPS ----
800 INPUT "ACRES TO PLANT WITH SEED? ", D
810 IF D = 0 THEN GOTO 900
820 IF D < 0 THEN GOTO 1900
830 IF D <= A THEN GOTO 850
840 PRINT "YOU ONLY OWN ", A, " ACRES!"
845 GOTO 800
850 IF D / 2 <= S THEN GOTO 870
860 PRINT "YOU NEED ", D / 2, " BUSHELS FOR SEED!"
865 GOTO 800
870 IF D < 10 * P THEN GOTO 890
880 PRINT "YOU ONLY HAVE ", P, " PEOPLE!"
885 GOTO 800
890 LET S = S - D / 2
900 REM ---- CALCULATE HARVEST ----
910 LET C = RND(5) + 1
920 LET Y = C
930 LET H = D * Y
940 LET E = 0
950 LET C = RND(5) + 1
960 REM ---- RATS ----
970 LET R = C / 2 * 2
980 IF R = C THEN GOTO 1000
990 LET E = S / C
1000 LET S = S - E + H
1010 REM ---- BIRTHS ----
1020 LET C = RND(5) + 1
1030 LET I = C * (20 * A + S) / P / 100 + 1
1040 REM ---- STARVATION ----
1050 LET C = Q / 20
1060 REM ---- PLAGUE (15% CHANCE) ----
1070 LET Q = RND(20)
1080 IF Q > 2 THEN GOTO 1100
1090 LET Q = 0
1095 GOTO 1100
1100 IF P < C THEN GOTO 320
1110 LET D = P - C
1120 IF D * 100 / P > 45 THEN GOTO 1800
1130 LET P1 = ((Z - 1) * P1 + D * 100 / P) / Z
1140 LET P = C
1150 LET D1 = D1 + D
1160 GOTO 340
1170 REM
1800 REM ---- IMPEACHMENT ----
1810 PRINT ""
1820 PRINT "YOU STARVED ", D, " PEOPLE IN ONE YEAR!"
1830 PRINT "DUE TO THIS EXTREME MISMANAGEMENT"
1840 PRINT "YOU HAVE BEEN IMPEACHED AND THROWN"
1850 PRINT "OUT OF OFFICE!"
1860 GOTO 2500
1900 REM ---- QUIT ----
1910 PRINT ""
1920 PRINT "HAMURABI: I CANNOT DO WHAT YOU WISH."
1930 PRINT "GET YOURSELF ANOTHER STEWARD!"
1940 GOTO 2500
2000 REM ---- FINAL REPORT ----
2010 PRINT "IN YOUR 10-YEAR TERM,"
2020 PRINT P1, " PERCENT STARVED PER YEAR"
2030 PRINT "A TOTAL OF ", D1, " PEOPLE DIED"
2040 LET L = A / P
2050 PRINT "YOU ENDED WITH ", L, " ACRES PER PERSON"
2060 PRINT ""
2070 IF P1 > 33 THEN GOTO 1810
2080 IF L < 7 THEN GOTO 1810
2090 IF P1 > 10 THEN GOTO 2200
2100 IF L < 9 THEN GOTO 2200
2110 IF P1 > 3 THEN GOTO 2300
2120 IF L < 10 THEN GOTO 2300
2130 PRINT "A FANTASTIC PERFORMANCE!"
2140 PRINT "CHARLEMAGNE, DISRAELI, AND"
2150 PRINT "JEFFERSON COMBINED COULD NOT"
2160 PRINT "HAVE DONE BETTER!"
2170 GOTO 2500
2200 PRINT "YOUR HEAVY-HANDED PERFORMANCE"
2210 PRINT "SMACKS OF NERO AND IVAN IV."
2220 PRINT "THE PEOPLE HATE YOUR GUTS!"
2230 GOTO 2500
2300 PRINT "YOUR PERFORMANCE COULD HAVE"
2310 PRINT "BEEN SOMEWHAT BETTER, BUT"
2320 PRINT "REALLY WASN'T TOO BAD AT ALL."
2330 LET R = RND(P)
2340 PRINT R, " PEOPLE WOULD DEARLY LIKE"
2350 PRINT "TO SEE YOU ASSASSINATED."
2500 REM ---- END ----
2510 PRINT ""
2520 PRINT "SO LONG FOR NOW."
